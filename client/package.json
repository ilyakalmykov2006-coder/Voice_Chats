{
  "name": "voice-chats-client",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/electron-main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "mediasoup-client": "^3.7.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.voicechats.desktop",
    "productName": "VoiceChats",
    "files": [
      "dist/**",
      "dist-electron/**",
      "config.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "VoiceChats-${version}.${ext}"
    }
  }
}
