NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=yourStrong(!)Password
DB_NAME=YourDB

JWT_ACCESS_SECRET=replace_access_secret
JWT_REFRESH_SECRET=replace_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

TURN_REALM=chat.example.com
TURN_STATIC_AUTH_SECRET=replace_turn_secret
TURN_TTL_SECONDS=600
TURN_UDP_URL=turn:chat.example.com:3478?transport=udp
TURN_TCP_URL=turn:chat.example.com:3478?transport=tcp
TURN_TLS_URL=turns:chat.example.com:5349?transport=tcp

MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_RTP_MIN_PORT=40000
MEDIASOUP_RTP_MAX_PORT=40100
